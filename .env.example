# Supabase configuration
# Copy this file to .env and fill in your actual values
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-supabase-project-id.supabase.co"

# Supabase Edge Functions secrets
# Set these via: supabase secrets set --env-file supabase/functions/.env
# Or individually: supabase secrets set STRIPE_SECRET_KEY=sk_live_...
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Stripe configuration (required for payment Edge Functions)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Azure AI Services ─────────────────────────────────────────────────────────
# Obtain these from https://portal.azure.com → Keys and Endpoint for each resource.
# When these variables are set the app uses Azure services directly;
# otherwise it falls back to the existing Supabase Edge Functions.

# Azure OpenAI  (resource: Azure OpenAI → Keys and Endpoint)
VITE_AZURE_OPENAI_KEY=
VITE_AZURE_OPENAI_ENDPOINT=
VITE_AZURE_OPENAI_DEPLOYMENT=

# Azure Speech  (resource: Speech → Keys and Endpoint)
VITE_AZURE_SPEECH_KEY=
VITE_AZURE_SPEECH_REGION=

# Azure Translator  (resource: Translator → Keys and Endpoint)
VITE_AZURE_TRANSLATOR_KEY=
VITE_AZURE_TRANSLATOR_REGION=

# Azure Face / Vision  (resource: Face API → Keys and Endpoint)
VITE_AZURE_FACE_KEY=
VITE_AZURE_FACE_ENDPOINT=

# Azure Blob Storage  (resource: Storage Account → Shared Access Signature)
VITE_AZURE_STORAGE_ACCOUNT=
VITE_AZURE_STORAGE_SAS_TOKEN=
