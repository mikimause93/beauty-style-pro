# Supabase configuration
# Copy this file to .env and fill in your actual values
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-supabase-project-id.supabase.co"

# VAPID keys for Web Push notifications (background push when app is closed)
# Generate with: npx web-push generate-vapid-keys
# Set the PUBLIC key here (client-visible), store PRIVATE key as Supabase secret
VITE_VAPID_PUBLIC_KEY=""

# Supabase Edge Functions secrets
# Set these via: supabase secrets set --env-file supabase/functions/.env
# Or individually: supabase secrets set STRIPE_SECRET_KEY=sk_live_...
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# VAPID private key for the send-push-notification Edge Function
# supabase secrets set VAPID_PRIVATE_KEY=... VAPID_PUBLIC_KEY=... VAPID_SUBJECT=mailto:admin@yourdomain.com
VAPID_PRIVATE_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_SUBJECT="mailto:admin@style.app"

# Stripe configuration (required for payment Edge Functions)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
