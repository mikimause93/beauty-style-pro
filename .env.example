# ============================================================
# Beauty Style Pro v2.0.0 — Environment Variables
# Copia questo file in .env e compila i valori reali
# ============================================================

# ── Supabase (esistente) ─────────────────────────────────────
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-supabase-project-id.supabase.co"

# Supabase Edge Functions secrets
# Set these via: supabase secrets set --env-file supabase/functions/.env
# Or individually: supabase secrets set STRIPE_SECRET_KEY=sk_live_...
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Stripe configuration (required for payment Edge Functions)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Stella AI Service v2 (FastAPI — porta 8001) ──────────────
# URL del microservizio Stella AI (GPT-4o + RAG Pinecone)
VITE_STELLA_AI_URL="http://localhost:8001"

# ── Stella Voice Service v2 (FastAPI — porta 8002) ───────────
# URL del microservizio voice (Whisper STT + ElevenLabs TTS)
VITE_STELLA_VOICE_URL="http://localhost:8002"

# ── OpenAI ───────────────────────────────────────────────────
# Usata dal stella-ai microservice (non esporre nel frontend!)
OPENAI_API_KEY="sk-..."

# ── ElevenLabs TTS ───────────────────────────────────────────
# ID della voce italiana di Stella su ElevenLabs
VITE_ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
# API key (usata dal voice service — non esporre nel frontend!)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# ── Pinecone Vector DB ───────────────────────────────────────
# Usata dal stella-ai microservice (non esporre nel frontend!)
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX="beauty-style-pro-memory"
PINECONE_ENVIRONMENT="us-east-1-aws"

# ── LiveKit WebRTC ───────────────────────────────────────────
# URL del server LiveKit (es. wss://your-livekit.livekit.cloud)
VITE_LIVEKIT_URL="wss://localhost:7880"
# API key e secret (solo backend/server-side — non esporre!)
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"

# ── Redis Cache ───────────────────────────────────────────────
# URL Redis per cache, sessioni e rate limiting (solo backend)
REDIS_URL="redis://localhost:6379"

# ── Porcupine Wake Word ───────────────────────────────────────
# Access key Picovoice per wake word "Stella" on-device
VITE_PORCUPINE_ACCESS_KEY="your-porcupine-access-key"
