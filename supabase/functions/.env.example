# Supabase Edge Functions local development secrets
# Copy this file to supabase/functions/.env and fill in your actual values
# This file is loaded automatically when running: supabase functions serve <function-name>
# Or specify a custom file with: supabase functions serve <function-name> --env-file path/to/.env
#
# To set secrets in production, run:
#   supabase secrets set --env-file supabase/functions/.env
# Or set individually:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_...
#
# To list all remote secrets:
#   supabase secrets list

# Supabase (SUPABASE_URL and SUPABASE_ANON_KEY are auto-injected in production)
# SUPABASE_SERVICE_ROLE_KEY must be set manually via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Stripe (required for payment Edge Functions)
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Get your webhook secret at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."
